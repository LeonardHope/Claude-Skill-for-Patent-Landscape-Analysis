            : escapeHtml(row.publication_number);
          return "<tr>" +
            "<td class='col-rank'>" + row.rank + "</td>" +
            "<td class='col-title'>" +
              "<div style='font-weight:500'>" + escapeHtml(row.title || row.publication_number) + "</div>" +
              "<div style='font-size:11px;color:#a0aec0;margin-top:2px'>" + link + " &middot; " + escapeHtml(row.jurisdiction || "") + "</div>" +
            "</td>" +
            "<td class='col-applicant'>" + escapeHtml(row.applicant || "") + "</td>" +
            "<td class='col-year'>" + (row.year || "\u2014") + "</td>" +
