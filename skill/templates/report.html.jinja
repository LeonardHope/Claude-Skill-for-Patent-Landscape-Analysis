<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ query_label }}</title>
  <style>
    /* ===== Theme tokens ===== */
    :root {
      /* Surfaces */
      --bg: #0f1419;
      --surface: #ffffff;
      --surface-alt: #f8fafc;
      --surface-panel: #ffffff;
      --border: #e5e7eb;
      --border-strong: #cbd5e0;
      --border-subtle: #f1f5f9;
      /* Text */
      --text-primary: #0f172a;
      --text-secondary: #475569;
      --text-muted: #94a3b8;
      --text-on-dark: #f8fafc;
      /* Brand palette (5-color system) */
      --c-blue: #0062b8;
      --c-blue-deep: #003a6b;
      --c-blue-light: #4ea5e0;
      --c-blue-pale: #e0ecf9;
      --c-teal: #0d9488;
      --c-teal-light: #14b8a6;
      --c-teal-pale: #ccfbf1;
      --c-amber: #f59e0b;
      --c-amber-light: #fbbf24;
      --c-amber-pale: #fef3c7;
      --c-rose: #e11d48;
      --c-rose-light: #f43f5e;
      --c-rose-pale: #ffe4e6;
      --c-violet: #7c3aed;
      --c-violet-light: #a78bfa;
      --c-violet-pale: #ede9fe;
      /* Legacy aliases (some CSS still references these) */
      --accent: var(--c-blue-deep);
      --accent-dark: #00264a;
      --accent-mid: var(--c-blue);
      --accent-light: var(--c-blue-light);
      --accent-pale: var(--c-blue-pale);
      --accent-glow: rgba(0, 58, 107, 0.12);
      --amber: var(--c-amber);
      --amber-pale: var(--c-amber-pale);
      /* Neutrals */
      --grid: #f1f5f9;
      --danger: #b91c1c;
      --success: #047857;
      /* Shadows */
      --shadow-sm: 0 1px 2px rgba(15,23,42,0.04), 0 1px 3px rgba(15,23,42,0.05);
      --shadow-md: 0 4px 12px -2px rgba(15,23,42,0.08), 0 2px 4px -1px rgba(15,23,42,0.04);
      --shadow-lg: 0 20px 40px -12px rgba(15,23,42,0.18), 0 12px 20px -8px rgba(15,23,42,0.08);
      --shadow-tile: 0 1px 3px rgba(15,23,42,0.06), 0 4px 12px -2px rgba(15,23,42,0.04);
      --shadow-tile-hover: 0 12px 28px -6px rgba(0,58,107,0.18), 0 4px 8px rgba(0,58,107,0.08);
      /* Radii */
      --radius: 12px;
      --radius-lg: 16px;
      --radius-sm: 8px;
      /* Chart palette — full multi-color range */
      --chart-palette-0: #0062b8;
      --chart-palette-1: #14b8a6;
      --chart-palette-2: #f59e0b;
      --chart-palette-3: #7c3aed;
      --chart-palette-4: #f43f5e;
      --chart-palette-5: #4ea5e0;
      --chart-palette-6: #10b981;
      --chart-palette-7: #fb923c;
      --chart-palette-8: #a78bfa;
    }

    /* ===== Base ===== */
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
      background: #f1f3f7;
      color: var(--text-primary);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      line-height: 1.55;
      font-size: 16px;
      font-feature-settings: "cv11", "ss01", "ss03";
    }
    /* Serif display font — falls back to system serifs (New York on macOS,
       Cambria on Windows, Georgia otherwise). */
    .display-serif {
      font-family: ui-serif, 'New York', 'Iowan Old Style', 'Palatino Linotype',
                   'Book Antiqua', Palatino, Cambria, Georgia, serif;
      font-feature-settings: "lnum";
    }
    h1, h2, h3, h4 {
      margin: 0;
      color: var(--text-primary);
      font-weight: 600;
      letter-spacing: -0.025em;
    }
    h1 { font-size: 32px; line-height: 1.15; font-weight: 700; letter-spacing: -0.03em; }
    h2 { font-size: 26px; line-height: 1.2; letter-spacing: -0.025em; }
    h3 { font-size: 15px; line-height: 1.3; }
    p { margin: 0; }
    a { color: var(--accent); text-decoration: none; transition: color 120ms; }
    a:hover { color: var(--accent-mid); text-decoration: underline; text-underline-offset: 2px; }
    button { font-family: inherit; cursor: pointer; }

    /* Fade-in on initial load */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .report-section {
      animation: fadeUp 500ms cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    .report-section:nth-child(1) { animation-delay: 0ms; }
    .report-section:nth-child(2) { animation-delay: 60ms; }
    .report-section:nth-child(3) { animation-delay: 120ms; }
    .report-section:nth-child(4) { animation-delay: 180ms; }
    .report-section:nth-child(5) { animation-delay: 240ms; }
    .report-section:nth-child(6) { animation-delay: 300ms; }
    .report-section:nth-child(7) { animation-delay: 360ms; }

    /* ===== Header ===== */
    /* ===== HERO (dark) ===== */
    .report-header {
      position: relative;
      padding: 80px 0 72px;
      background:
        radial-gradient(ellipse 1000px 500px at 15% 0%, rgba(78, 165, 224, 0.18), transparent 60%),
        radial-gradient(ellipse 800px 400px at 90% 100%, rgba(217, 119, 6, 0.10), transparent 60%),
        linear-gradient(160deg, #0a1628 0%, #0f2847 35%, #112e52 70%, #0c1e3a 100%);
      color: #f1f5f9;
      overflow: hidden;
    }
    /* Subtle dot grid overlay */
    .report-header::before {
      content: "";
      position: absolute;
      inset: 0;
      background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.04) 1px, transparent 0);
      background-size: 32px 32px;
      pointer-events: none;
    }
    .report-header::after {
      content: "";
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, #4ea5e0 0%, #0062b8 30%, #003a6b 60%, #d97706 100%);
    }
    .header-inner {
      position: relative;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 48px;
    }
    .report-kicker {
      font-size: 14px;
      color: #4ea5e0;
      text-transform: uppercase;
      letter-spacing: 0.28em;
      font-weight: 800;
      margin-bottom: 24px;
      display: inline-flex;
      align-items: center;
      gap: 14px;
    }
    .report-kicker::before {
      content: "";
      width: 40px;
      height: 2px;
      background: #4ea5e0;
    }
    .report-title-block h1 {
      /* Modern display sans — SF Pro Display on macOS, Segoe UI on Windows */
      font-family: system-ui, -apple-system, 'SF Pro Display', 'Segoe UI',
                   'Inter', 'Helvetica Neue', Arial, sans-serif;
      font-size: 60px;
      line-height: 1;
      margin-bottom: 18px;
      color: #ffffff;
      font-weight: 800;
      letter-spacing: -0.045em;
      max-width: 22ch;
      text-wrap: balance;
    }
    @media (max-width: 760px) { .report-title-block h1 { font-size: 40px; } }
    /* Accent underline under the title for color pop */
    .title-accent-bar {
      display: block;
      height: 4px;
      width: 120px;
      border-radius: 99px;
      background: linear-gradient(90deg, #4ea5e0 0%, #14b8a6 50%, #f59e0b 100%);
      margin-bottom: 24px;
    }
    .report-subtitle {
      font-size: 17px;
      color: rgba(241, 245, 249, 0.72);
      margin-bottom: 48px;
      font-weight: 400;
      max-width: 60ch;
      line-height: 1.55;
    }

    /* Hero narrative pullquote */
    .hero-narrative {
      font-family: system-ui, -apple-system, 'SF Pro Display', 'Segoe UI',
                   'Inter', 'Helvetica Neue', sans-serif;
      font-size: 22px;
      line-height: 1.5;
      color: rgba(255,255,255,0.95);
      font-weight: 500;
      letter-spacing: -0.018em;
      max-width: 68ch;
      margin-bottom: 52px;
      padding-left: 22px;
      border-left: 4px solid transparent;
      border-image: linear-gradient(180deg, #4ea5e0 0%, #14b8a6 50%, #f59e0b 100%) 1;
      white-space: pre-line;
    }
    .hero-narrative::first-line { font-weight: 600; }
    @media (max-width: 760px) { .hero-narrative { font-size: 18px; } }

    /* Hero stat tiles (dark variant, colored accents) */
    .hero-stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 18px;
      margin-bottom: 48px;
    }
    @media (max-width: 900px) { .hero-stats { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 520px) { .hero-stats { grid-template-columns: 1fr; } }
    .hero-stat {
      position: relative;
      background: linear-gradient(155deg, rgba(255,255,255,0.07) 0%, rgba(255,255,255,0.02) 100%);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 14px;
      padding: 28px 26px 26px;
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      transition: transform 260ms cubic-bezier(0.16, 1, 0.3, 1), border-color 260ms, background 260ms;
      overflow: hidden;
    }
    /* Each tile gets a different accent color — cycle through the 4-color system */
    .hero-stat:nth-child(1) { --accent-color: #4ea5e0; }
    .hero-stat:nth-child(2) { --accent-color: #14b8a6; }
    .hero-stat:nth-child(3) { --accent-color: #f59e0b; }
    .hero-stat:nth-child(4) { --accent-color: #f43f5e; }
    .hero-stat::before {
      content: "";
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: var(--accent-color);
      transform: scaleX(0.3);
      transform-origin: left;
      transition: transform 340ms cubic-bezier(0.16, 1, 0.3, 1);
    }
    .hero-stat::after {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 280px 180px at 20% 0%, var(--accent-color), transparent 60%);
      opacity: 0.08;
      pointer-events: none;
    }
    .hero-stat:hover {
      transform: translateY(-4px);
      border-color: color-mix(in srgb, var(--accent-color) 40%, transparent);
      background: linear-gradient(155deg, rgba(255,255,255,0.10) 0%, rgba(255,255,255,0.03) 100%);
    }
    .hero-stat:hover::before { transform: scaleX(1); }
    .hero-stat-label {
      position: relative;
      font-size: 10px;
      color: var(--accent-color);
      text-transform: uppercase;
      letter-spacing: 0.16em;
      font-weight: 700;
      margin-bottom: 14px;
    }
    .hero-stat-value {
      position: relative;
      font-family: system-ui, -apple-system, 'SF Pro Display', 'Segoe UI',
                   'Inter', 'Helvetica Neue', sans-serif;
      font-size: 52px;
      font-weight: 800;
      color: #ffffff;
      letter-spacing: -0.04em;
      line-height: 1;
      font-variant-numeric: tabular-nums lining-nums;
    }
    .hero-stat .why-btn {
      position: absolute;
      top: 16px;
      right: 16px;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.18);
      border-radius: 99px;
      width: 24px;
      height: 24px;
      font-size: 12px;
      font-weight: 700;
      color: rgba(241, 245, 249, 0.7);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0;
      transition: all 160ms;
    }
    .hero-stat .why-btn:hover {
      background: #4ea5e0;
      color: #0a1628;
      border-color: #4ea5e0;
      transform: scale(1.1);
    }

    /* Query context block inside hero */
    .query-context {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 28px 56px;
      padding: 28px 32px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: var(--radius);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
    }
    @media (max-width: 760px) { .query-context { grid-template-columns: 1fr; gap: 20px; padding: 22px; } }
    .qc-block-title {
      font-size: 11px;
      color: rgba(241, 245, 249, 0.6);
      text-transform: uppercase;
      letter-spacing: 0.14em;
      font-weight: 700;
      margin-bottom: 18px;
      padding-bottom: 12px;
      border-bottom: 1px solid rgba(255,255,255,0.12);
    }
    .qc-row {
      display: grid;
      grid-template-columns: 160px 1fr;
      gap: 4px 18px;
      font-size: 15px;
      padding: 8px 0;
      line-height: 1.4;
    }
    .qc-row dt {
      color: rgba(241, 245, 249, 0.6);
      font-weight: 500;
    }
    .qc-row dd {
      margin: 0;
      color: rgba(255, 255, 255, 0.95);
      font-weight: 500;
    }
    .qc-row code {
      background: rgba(78, 165, 224, 0.18);
      padding: 2px 8px;
      border-radius: 4px;
      font-size: 13px;
      color: #a5d8f3;
      font-family: 'SF Mono', ui-monospace, Consolas, monospace;
      font-weight: 600;
      margin-right: 4px;
      border: 1px solid rgba(78, 165, 224, 0.25);
    }

    /* ===== Nav ===== */
    .section-nav {
      background: rgba(255,255,255,0.85);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      position: sticky;
      top: 0;
      z-index: 20;
    }
    .nav-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 40px;
      display: flex;
      gap: 28px;
      overflow-x: auto;
    }
    .section-nav a {
      padding: 16px 0;
      font-size: 13px;
      font-weight: 500;
      color: var(--text-secondary);
      white-space: nowrap;
      border-bottom: 2px solid transparent;
      text-decoration: none;
      transition: color 160ms, border-color 160ms;
    }
    .section-nav a:hover {
      color: var(--accent);
      text-decoration: none;
      border-bottom-color: var(--accent);
    }

    /* ===== Main ===== */
    .report-main {
      max-width: 1200px;
      margin: 0 auto;
      padding: 48px 40px 64px;
    }
    .report-section {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-sm);
      padding: 40px 44px;
      margin-bottom: 28px;
      position: relative;
      overflow: hidden;
    }
    .report-section:hover { box-shadow: var(--shadow-md); }
    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 16px;
      margin-bottom: 28px;
      padding-bottom: 20px;
      border-bottom: 1px solid var(--border-subtle);
    }
    .section-kicker {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      font-weight: 700;
      margin-bottom: 8px;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }
    .section-kicker::before {
      content: "";
      width: 20px;
      height: 2px;
      background: currentColor;
      border-radius: 99px;
    }
    /* Each section's kicker gets a different accent color */
    #leaders .section-kicker { color: var(--c-blue); }
    #geography .section-kicker { color: var(--c-teal); }
    #trends .section-kicker { color: var(--c-amber); }
    #technology .section-kicker { color: var(--c-violet); }
    #notable .section-kicker { color: var(--c-rose); }
    #methodology .section-kicker { color: #64748b; }
    /* Section-specific accent strip at the top of each card */
    .report-section::before {
      content: "";
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      opacity: 0.85;
    }
    #leaders::before { background: linear-gradient(90deg, var(--c-blue), var(--c-blue-light)); }
    #geography::before { background: linear-gradient(90deg, var(--c-teal), var(--c-teal-light)); }
    #trends::before { background: linear-gradient(90deg, var(--c-amber), var(--c-amber-light)); }
    #technology::before { background: linear-gradient(90deg, var(--c-violet), var(--c-violet-light)); }
    #notable::before { background: linear-gradient(90deg, var(--c-rose), var(--c-rose-light)); }
    #methodology::before { background: linear-gradient(90deg, #475569, #94a3b8); }
    .section-header h2 {
      margin-bottom: 8px;
      letter-spacing: -0.025em;
      font-family: system-ui, -apple-system, 'SF Pro Display', 'Segoe UI',
                   'Inter', 'Helvetica Neue', sans-serif;
      font-weight: 700;
    }
    .section-subtitle {
      font-size: 15px;
      color: var(--text-secondary);
      font-weight: 400;
      line-height: 1.5;
    }

    /* ===== Hero action bar (Download + Help) ===== */
    .hero-actions {
      position: absolute;
      top: 48px;
      right: 48px;
      display: flex;
      align-items: center;
      gap: 10px;
      z-index: 5;
    }
    .download-btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 12px 22px;
      background: linear-gradient(135deg, #4ea5e0 0%, #14b8a6 100%);
      color: #0a1628;
      border: none;
      border-radius: 10px;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      box-shadow: 0 4px 12px rgba(78, 165, 224, 0.25);
      transition: transform 180ms, box-shadow 180ms;
      font-family: inherit;
    }
    .download-btn:hover {
      transform: translateY(-1px);
      box-shadow: 0 8px 24px rgba(78, 165, 224, 0.35);
    }
    .download-btn svg { width: 16px; height: 16px; }
    .download-dropdown { position: relative; }
    .download-menu {
      position: absolute;
      top: calc(100% + 8px);
      right: 0;
      min-width: 240px;
      background: #ffffff;
      border-radius: 12px;
      box-shadow: 0 20px 40px -12px rgba(15,23,42,0.35), 0 12px 20px -8px rgba(15,23,42,0.15);
      padding: 6px;
      display: none;
      z-index: 10;
    }
    .download-dropdown.open .download-menu { display: block; }
    .download-menu button {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      width: 100%;
      padding: 12px 14px;
      background: transparent;
      border: none;
      border-radius: 8px;
      text-align: left;
      cursor: pointer;
      font-family: inherit;
      transition: background 160ms;
    }
    .download-menu button:hover { background: var(--surface-alt); }
    .download-menu .item-icon {
      width: 32px;
      height: 32px;
      flex-shrink: 0;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--c-blue-pale);
      color: var(--c-blue);
    }
    .download-menu .item-icon svg { width: 16px; height: 16px; }
    .download-menu .item-body { flex: 1; }
    .download-menu .item-title {
      font-size: 14px;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 2px;
    }
    .download-menu .item-desc {
      font-size: 12px;
      color: var(--text-muted);
      line-height: 1.4;
    }

    /* Help tooltip (?) */
    .help-btn {
      position: relative;
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.2);
      color: rgba(255,255,255,0.8);
      font-size: 14px;
      font-weight: 700;
      cursor: help;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 160ms;
    }
    .help-btn:hover {
      background: rgba(255,255,255,0.15);
      color: #ffffff;
    }
    .help-tooltip {
      position: absolute;
      top: calc(100% + 12px);
      right: 0;
      width: 320px;
      padding: 14px 16px;
      background: #ffffff;
      color: var(--text-secondary);
      border-radius: 10px;
      font-size: 13px;
      font-weight: 400;
      line-height: 1.5;
      box-shadow: 0 20px 40px -12px rgba(15,23,42,0.35);
      opacity: 0;
      pointer-events: none;
      transform: translateY(-4px);
      transition: opacity 180ms, transform 180ms;
      z-index: 20;
      text-align: left;
    }
    .help-tooltip b { color: var(--text-primary); }
    .help-btn:hover .help-tooltip,
    .help-btn:focus .help-tooltip {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }

    /* ===== Headline ===== */
    .summary-block {
      background:
        linear-gradient(135deg, rgba(0,58,107,0.04) 0%, rgba(0,98,184,0.02) 100%);
      border-left: 4px solid var(--accent);
      padding: 28px 32px;
      border-radius: 0 var(--radius) var(--radius) 0;
      margin-bottom: 32px;
      position: relative;
    }
    .summary-text {
      font-size: 18px;
      color: var(--text-primary);
      white-space: pre-line;
      line-height: 1.65;
      font-weight: 400;
      letter-spacing: -0.005em;
    }
    .summary-text::first-line { font-weight: 500; }
    .stat-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
    }
    @media (max-width: 900px) { .stat-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 520px) { .stat-grid { grid-template-columns: 1fr; } }
    .stat-tile {
      position: relative;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 28px 24px 26px;
      box-shadow: var(--shadow-tile);
      transition: transform 200ms cubic-bezier(0.16, 1, 0.3, 1), box-shadow 200ms, border-color 200ms;
      overflow: hidden;
    }
    .stat-tile::before {
      content: "";
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--accent) 0%, var(--accent-mid) 100%);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 280ms cubic-bezier(0.16, 1, 0.3, 1);
    }
    .stat-tile:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-tile-hover);
      border-color: var(--accent-light);
    }
    .stat-tile:hover::before { transform: scaleX(1); }
    .stat-label {
      font-size: 10px;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-weight: 700;
      margin-bottom: 12px;
    }
    .stat-value {
      font-size: 48px;
      font-weight: 700;
      color: var(--text-primary);
      letter-spacing: -0.035em;
      line-height: 1;
      font-variant-numeric: tabular-nums;
      background: linear-gradient(135deg, var(--text-primary) 0%, var(--accent) 130%);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .why-btn {
      position: absolute;
      top: 14px;
      right: 14px;
      background: transparent;
      border: 1px solid var(--border);
      border-radius: 99px;
      width: 24px;
      height: 24px;
      font-size: 12px;
      font-weight: 700;
      color: var(--text-muted);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0;
      transition: all 160ms;
    }
    .why-btn:hover {
      background: var(--accent);
      color: #fff;
      border-color: var(--accent);
      transform: scale(1.1);
    }

    /* ===== Chart wrapper ===== */
    .chart-wrap {
      position: relative;
      margin-top: 4px;
    }
    .chart-actions {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 8px;
      margin-bottom: 8px;
    }
    .chart {
      width: 100%;
      min-height: 360px;
    }
    .chart-tall { min-height: 500px; }
    .chart-short { min-height: 300px; }
    .icon-btn {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 6px 12px;
      font-size: 12px;
      font-weight: 500;
      color: var(--text-secondary);
      display: inline-flex;
      align-items: center;
      gap: 6px;
      cursor: pointer;
    }
    .icon-btn:hover {
      background: var(--surface-alt);
      border-color: var(--border-strong);
      color: var(--text-primary);
    }
    .icon-btn svg { width: 13px; height: 13px; }
    .export-dropdown { position: relative; }
    .export-menu {
      position: absolute;
      top: 100%;
      right: 0;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      box-shadow: var(--shadow-md);
      padding: 4px;
      margin-top: 4px;
      display: none;
      min-width: 160px;
      z-index: 10;
    }
    .export-dropdown.open .export-menu { display: block; }
    .export-menu button {
      display: flex;
      align-items: center;
      gap: 8px;
      width: 100%;
      background: transparent;
      border: none;
      padding: 8px 12px;
      font-size: 12px;
      color: var(--text-secondary);
      text-align: left;
      border-radius: 4px;
      cursor: pointer;
    }
    .export-menu button:hover { background: var(--surface-alt); color: var(--text-primary); }

    /* ===== Geography footnote (regional offices) =====
       Regional offices like EPO and WIPO can't be plotted on a country map
       because they don't correspond to a single country. Rather than living
       in a permanent sidebar (which was confusing — it looked like the right
       half of the map "stuck" on Europe), they're now a small footnote row
       directly below the map, framed as "additional filings not plotted". */
    .map-footnote {
      margin-top: 14px;
      padding: 14px 18px;
      background: var(--surface-alt);
      border: 1px solid var(--border);
      border-radius: 8px;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 20px;
    }
    .map-footnote-label {
      font-size: 11px;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.14em;
      font-weight: 700;
      margin-right: 4px;
    }
    .map-footnote-item {
      display: inline-flex;
      align-items: baseline;
      gap: 8px;
      font-size: 14px;
      color: var(--text-secondary);
      cursor: pointer;
      padding: 4px 8px;
      border-radius: 6px;
      transition: background 160ms;
    }
    .map-footnote-item:hover { background: var(--surface); }
    .map-footnote-item strong {
      color: var(--text-primary);
      font-weight: 700;
    }
    .map-footnote-item .count {
      font-variant-numeric: tabular-nums;
      color: var(--c-teal);
      font-weight: 800;
      font-size: 16px;
    }
    .map-footnote-help {
      font-size: 12px;
      color: var(--text-muted);
      font-style: italic;
      margin-left: auto;
    }

    /* ===== Notable patents table ===== */
    .notable-criterion {
      font-size: 14px;
      color: var(--text-muted);
      margin-bottom: 16px;
    }
    .notable-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
    }
    .notable-table th {
      text-align: left;
      padding: 10px 14px;
      color: var(--text-muted);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-weight: 700;
      border-bottom: 1px solid var(--border);
    }
    .notable-table td {
      padding: 14px;
      border-bottom: 1px solid var(--grid);
    }
    .notable-table tr:last-child td { border-bottom: none; }
    .notable-table .col-rank { width: 40px; color: var(--text-muted); font-weight: 700; }
    .notable-table .col-count {
      width: 80px;
      text-align: right;
      color: var(--c-rose);
      font-weight: 800;
      font-size: 16px;
    }
    .notable-table .col-title { color: var(--text-primary); }
    .notable-table .col-year { width: 60px; color: var(--text-muted); font-size: 13px; }
    .notable-table .col-applicant { color: var(--text-secondary); font-size: 13px; }

    /* ===== Methodology ===== */
    .methodology-block { margin-bottom: 28px; }
    .methodology-block:last-child { margin-bottom: 0; }
    .methodology-block h3 {
      font-size: 11px;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-weight: 700;
      margin-bottom: 10px;
    }
    .methodology-block p,
    .methodology-block li {
      font-size: 14px;
      color: var(--text-secondary);
      line-height: 1.65;
    }
    .methodology-block ul {
      margin: 0;
      padding-left: 20px;
    }
    .methodology-block code {
      background: var(--surface-alt);
      padding: 3px 8px;
      border-radius: 4px;
      font-size: 13px;
      color: var(--accent);
      font-weight: 600;
      font-family: 'SF Mono', ui-monospace, Consolas, monospace;
    }
    /* Document type breakdown (methodology) */
    .doctype-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 12px;
      margin-top: 10px;
    }
    .doctype-pill {
      background: var(--surface-alt);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 14px 16px;
      position: relative;
      overflow: hidden;
    }
    .doctype-pill::before {
      content: "";
      position: absolute;
      top: 0; left: 0; bottom: 0;
      width: 3px;
      background: var(--c-blue);
    }
    .doctype-pill[data-kind="Granted patent"]::before { background: var(--c-teal); }
    .doctype-pill[data-kind="Patent application"]::before { background: var(--c-blue); }
    .doctype-pill[data-kind="Utility model"]::before { background: var(--c-amber); }
    .doctype-pill[data-kind="Design patent"]::before { background: var(--c-violet); }
    .doctype-pill[data-kind="Plant patent"]::before { background: var(--c-rose); }
    .doctype-pill[data-kind="Unknown"]::before { background: #94a3b8; }
    .doctype-label {
      font-size: 12px;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-weight: 700;
      margin-bottom: 6px;
    }
    .doctype-count {
      font-size: 26px;
      font-weight: 800;
      color: var(--text-primary);
      letter-spacing: -0.02em;
      line-height: 1;
      font-variant-numeric: tabular-nums;
    }
    .doctype-share {
      font-size: 13px;
      color: var(--text-muted);
      margin-top: 4px;
    }

    .merge-list {
      max-height: 280px;
      overflow-y: auto;
      background: var(--surface-alt);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 14px 18px;
      font-size: 13px;
    }
    .merge-item {
      padding: 8px 0;
      border-bottom: 1px solid var(--border);
    }
    .merge-item:last-child { border-bottom: none; }
    .merge-canonical {
      font-weight: 600;
      color: var(--text-primary);
    }
    .merge-variants {
      color: var(--text-muted);
      margin-top: 3px;
      font-size: 12px;
    }

    /* ===== Receipts panel ===== */
    .panel-overlay {
      position: fixed;
      inset: 0;
      background: rgba(15,23,42,0.35);
      z-index: 100;
      opacity: 0;
      pointer-events: none;
      transition: opacity 180ms ease;
    }
    .panel-overlay.visible { opacity: 1; pointer-events: auto; }
    .receipts-panel {
      position: fixed;
      top: 0;
      right: 0;
      bottom: 0;
      width: 480px;
      max-width: 95vw;
      background: var(--surface);
      box-shadow: var(--shadow-lg);
      z-index: 110;
      transform: translateX(100%);
      transition: transform 220ms cubic-bezier(0.16, 1, 0.3, 1);
      display: flex;
      flex-direction: column;
    }
    .receipts-panel.visible { transform: translateX(0); }
    .panel-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 20px 24px;
      border-bottom: 1px solid var(--border);
    }
    .panel-close {
      background: transparent;
      border: none;
      font-size: 24px;
      color: var(--text-muted);
      padding: 0 4px;
      line-height: 1;
    }
    .panel-close:hover { color: var(--text-primary); }
    .panel-body {
      flex: 1;
      overflow-y: auto;
      padding: 22px 26px;
    }
    .panel-label {
      font-size: 11px;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-weight: 700;
      margin: 20px 0 8px;
    }
    .panel-label:first-child { margin-top: 0; }
    .panel-text {
      font-size: 14px;
      color: var(--text-secondary);
      line-height: 1.6;
    }
    .panel-formula {
      background: var(--surface-alt);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 12px 14px;
      font-family: 'SF Mono', ui-monospace, 'Consolas', monospace;
      font-size: 13px;
      color: var(--text-primary);
      line-height: 1.55;
      white-space: pre-wrap;
      word-break: break-word;
    }
    .panel-quant {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 8px 16px;
      font-size: 14px;
      background: var(--surface-alt);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 14px 16px;
    }
    .panel-quant dt { color: var(--text-muted); }
    .panel-quant dd { margin: 0; color: var(--text-primary); font-weight: 700; text-align: right; }
    .panel-records {
      max-height: 360px;
      overflow-y: auto;
      background: var(--surface-alt);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 6px;
    }
    .panel-record {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 12px;
      font-size: 13px;
      border-radius: 4px;
    }
    .panel-record:hover { background: var(--surface); }
    .panel-record-title {
      color: var(--text-primary);
      font-weight: 500;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      max-width: 300px;
    }
    .panel-record-meta {
      font-size: 12px;
      color: var(--text-muted);
      flex-shrink: 0;
    }
    /* Applicant grouping inside drill-downs */
    .panel-applicant-group {
      background: var(--surface-alt);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 4px;
      margin-bottom: 10px;
    }
    .panel-applicant-group summary {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 10px 12px;
      cursor: pointer;
      list-style: none;
      border-radius: 6px;
      font-size: 14px;
    }
    .panel-applicant-group summary::-webkit-details-marker { display: none; }
    .panel-applicant-group summary:hover { background: var(--surface); }
    .panel-applicant-group[open] > summary {
      border-bottom: 1px solid var(--border);
      margin-bottom: 4px;
      border-radius: 6px 6px 0 0;
    }
    .panel-applicant-name {
      font-weight: 600;
      color: var(--text-primary);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      max-width: 280px;
    }
    .panel-applicant-count {
      font-size: 12px;
      color: var(--text-muted);
      font-weight: 600;
      background: var(--c-blue-pale);
      color: var(--c-blue);
      padding: 2px 8px;
      border-radius: 10px;
      margin-left: 8px;
    }
    .panel-applicant-disclosure {
      color: var(--text-muted);
      font-size: 12px;
      margin-left: 8px;
    }
    .panel-applicant-group[open] .panel-applicant-disclosure { transform: rotate(90deg); }
    .panel-applicant-disclosure { display: inline-block; transition: transform 160ms; }
    .panel-caveats {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .panel-caveats li {
      padding: 8px 0;
      font-size: 13px;
      color: var(--text-secondary);
      line-height: 1.55;
      border-bottom: 1px solid var(--grid);
    }
    .panel-caveats li:last-child { border-bottom: none; }
    .panel-caveats li::before { content: "\u2014 "; color: var(--text-muted); }

    /* ===== Footer ===== */
    .report-footer {
      max-width: 1200px;
      margin: 0 auto;
      padding: 32px;
      text-align: center;
      color: var(--text-muted);
      font-size: 12px;
    }

    /* ===== Print ===== */
    @media print {
      .section-nav, .chart-actions, .why-btn, .qc-share-note,
      .panel-overlay, .receipts-panel { display: none !important; }
      .report-section { break-inside: avoid; box-shadow: none; border: 1px solid #e5e7eb; }
      body { background: #fff; }
    }

    /* ===== Filter bar ===== */
    .filter-bar {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-sm);
      padding: 20px 28px;
      margin-bottom: 28px;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 12px;
    }
    .filter-label {
      font-size: 12px;
      font-weight: 700;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      margin-right: 4px;
    }
    .filter-pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 16px;
      border-radius: 99px;
      border: 1.5px solid var(--border);
      background: var(--surface);
      font-size: 13px;
      font-weight: 600;
      color: var(--text-secondary);
      cursor: pointer;
      transition: all 160ms;
      user-select: none;
    }
    .filter-pill:hover { border-color: var(--c-blue-light); }
    .filter-pill.active {
      background: var(--c-blue);
      border-color: var(--c-blue);
      color: #fff;
    }
    .filter-pill.active[data-type="Granted patent"] { background: var(--c-teal); border-color: var(--c-teal); }
    .filter-pill.active[data-type="Patent application"] { background: var(--c-blue); border-color: var(--c-blue); }
    .filter-pill.active[data-type="Utility model"] { background: var(--c-amber); border-color: var(--c-amber); color: #0f172a; }
    .filter-pill.active[data-type="Design patent"] { background: var(--c-violet); border-color: var(--c-violet); }
    .filter-pill .pill-count {
      font-size: 11px;
      font-weight: 700;
      opacity: 0.8;
    }
    .filter-summary {
      margin-left: auto;
      font-size: 13px;
      color: var(--text-muted);
      font-weight: 500;
    }
    .filter-summary strong { color: var(--text-primary); font-weight: 700; }
    .filter-reset {
      font-size: 12px;
      color: var(--c-blue);
      background: none;
      border: none;
      font-weight: 600;
      cursor: pointer;
      padding: 4px 8px;
      border-radius: 6px;
    }
    .filter-reset:hover { background: var(--c-blue-pale); }

    /* ===== Spotlight dropdown ===== */
    .spotlight-select {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 16px 8px 12px;
      border: 1.5px solid var(--border);
      border-radius: 8px;
      background: var(--surface);
      font-size: 13px;
      font-weight: 600;
      color: var(--text-secondary);
      cursor: pointer;
      font-family: inherit;
    }

    .hidden { display: none !important; }
  </style>
</head>
<body>
  <header class="report-header">
    <div class="header-inner">

      <div class="hero-actions">
        <div class="download-dropdown" id="download-dropdown">
          <button class="download-btn" id="download-btn" type="button">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10 3v11"/>
              <path d="M5 9l5 5 5-5"/>
              <path d="M3 17h14"/>
            </svg>
            Download
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" style="width:12px;height:12px">
              <polyline points="5 8 10 13 15 8"/>
            </svg>
          </button>
          <div class="download-menu" id="download-menu">
            <button data-action="download-html">
              <div class="item-icon" style="background: var(--c-blue-pale); color: var(--c-blue);">
                <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2H5a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V6z"/><path d="M13 2v4h4"/><path d="M7 13l3 3 3-3"/><path d="M10 16V9"/></svg>
              </div>
              <div class="item-body">
                <div class="item-title">Interactive report (HTML)</div>
                <div class="item-desc">The full report file &mdash; save, email, archive. Opens offline, stays interactive.</div>
              </div>
            </button>
            <button data-action="download-csv">
              <div class="item-icon" style="background: var(--c-teal-pale); color: var(--c-teal);">
                <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 5h14M3 10h14M3 15h14"/><path d="M8 3v14M13 3v14"/></svg>
              </div>
              <div class="item-body">
                <div class="item-title">Underlying data (CSV)</div>
                <div class="item-desc">Spreadsheet of the records behind the charts</div>
              </div>
            </button>
            <button data-action="print-pdf">
              <div class="item-icon" style="background: var(--c-amber-pale); color: var(--c-amber);">
                <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2h8l4 4v12a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2z"/><path d="M14 2v4h4"/></svg>
              </div>
              <div class="item-body">
                <div class="item-title">Printable PDF (static)</div>
                <div class="item-desc">Opens browser print dialog \u2014 choose "Save as PDF". No interactivity.</div>
              </div>
            </button>
          </div>
        </div>
        <button class="help-btn" type="button" tabindex="0" aria-label="About this file">
          ?
          <div class="help-tooltip">
            <b>This is a self-contained interactive HTML report.</b> It works offline, opens in any
            browser, and keeps every drill-down, receipt, and chart export working. Email it,
            archive it, or save it to a project folder &mdash; it stays interactive forever. Click
            <b>Download</b> to save a copy of this file, grab the underlying data as CSV, or print
            a static PDF.
          </div>
        </button>
      </div>

      <div class="report-title-block">
        <div class="report-kicker">Patent Landscape Report</div>
        <h1>{{ query_label }}</h1>
        <span class="title-accent-bar"></span>
        <div class="report-subtitle" id="report-subtitle">Loading&hellip;</div>
      </div>

      <div class="hero-narrative" id="hero-narrative">Loading&hellip;</div>

      <div class="hero-stats">
        <div class="hero-stat">
          <div class="hero-stat-label">Patent families</div>
          <div class="hero-stat-value" id="stat-families">&mdash;</div>
          <button class="why-btn" data-metric="headline_total_families" title="Show receipts">?</button>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-label">Distinct applicants</div>
          <div class="hero-stat-value" id="stat-applicants">&mdash;</div>
          <button class="why-btn" data-metric="headline_total_applicants" title="Show receipts">?</button>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-label">Jurisdictions</div>
          <div class="hero-stat-value" id="stat-jurisdictions">&mdash;</div>
          <button class="why-btn" data-metric="headline_total_jurisdictions" title="Show receipts">?</button>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-label">Peak filing year</div>
          <div class="hero-stat-value" id="stat-peak">&mdash;</div>
          <button class="why-btn" data-metric="headline_peak_year" title="Show receipts">?</button>
        </div>
      </div>

      <dl class="query-context" id="query-context">
        <div class="qc-block" id="qc-search"></div>
