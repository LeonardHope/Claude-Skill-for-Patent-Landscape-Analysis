  <!-- Runtime -->
  <script>
    (function() {
      "use strict";

      // ===== Constants =====
      const THEME = {
        accent: "#0062b8",
        accentDark: "#003a6b",
        accentMid: "#0062b8",
        accentLight: "#4ea5e0",
        accentPale: "#e0ecf9",
        teal: "#14b8a6",
        amber: "#f59e0b",
        rose: "#f43f5e",
        violet: "#7c3aed",
        textPrimary: "#0f172a",
        textSecondary: "#475569",
        textMuted: "#94a3b8",
        grid: "#f1f5f9",
        border: "#e5e7eb",
        surface: "#ffffff",
        // Full multi-color palette for categorical charts
        palette: [
          "#0062b8", "#14b8a6", "#f59e0b", "#7c3aed",
          "#f43f5e", "#4ea5e0", "#10b981", "#fb923c",
          "#a78bfa"
        ],
        // Map uses a refined blue ramp — don't want 10 colors on a choropleth
        mapRamp: ["#e0ecf9", "#b8d4f0", "#8bb8e5", "#4ea5e0", "#2874a6", "#0062b8", "#003a6b"],
        mapEmpty: "#f1f5f9",
        mapBorder: "#cbd5e0",
      };

      const REPORT = JSON.parse(document.getElementById("report-data-json").textContent);
      const WORLD = JSON.parse(document.getElementById("world-geo-json").textContent);

      // Chart registry: id -> ECharts instance
      const charts = {};

      // Record lookup: pub_number -> record (built from expanded ALL_RECORDS,
      // NOT from REPORT.records which has abbreviated single-char keys)
      const recordById = {};
      // Populated after ALL_RECORDS is built (see below)

      // ===== Init =====
      document.addEventListener("DOMContentLoaded", function() {
        try {
          echarts.registerMap("world", WORLD);
        } catch (e) {
          console.error("Failed to register world map", e);
        }
        renderQueryContext();
        renderHeadline();
        initTopApplicants();
        initWorldMap();
        renderRegionalCallouts();
        initJurisdictionBars();
        initFilingTrends();
        initJurisdictionTrends();
        initTechnologyAreas();
        renderNotable();
        renderDocTypes();
        renderMethodology();
        wireUpPanelEvents();
        wireUpExportMenus();
        wireUpDownloadMenu();
        wireUpFilterAndSpotlight();
        window.addEventListener("resize", resizeAllCharts);
      });

      // ===== Helpers =====
      function metric(id) { return REPORT.metrics[id]; }

      function formatInt(n) {
        if (n == null) return "\u2014";
        return Number(n).toLocaleString();
      }

      function baseAxisStyle() {
        return {
          axisLine: { show: false },
          axisTick: { show: false },
          axisLabel: { color: THEME.textSecondary, fontSize: 13, fontWeight: 500 },
          splitLine: { lineStyle: { color: THEME.grid, type: "dashed" } },
        };
      }

      function commonChartOptions(title) {
        return {
          title: title ? {
            text: title,
            textStyle: { color: THEME.textPrimary, fontSize: 14, fontWeight: 600 },
            left: 0, top: 0,
          } : undefined,
          tooltip: {
            trigger: "item",
            backgroundColor: "#ffffff",
            borderColor: THEME.border,
            borderWidth: 1,
            textStyle: { color: THEME.textPrimary, fontSize: 12 },
            padding: [8, 12],
            extraCssText: "box-shadow: 0 4px 12px rgba(15,23,42,0.08);",
          },
          grid: { top: 30, left: 8, right: 40, bottom: 30, containLabel: true },
          color: THEME.palette,
        };
      }

      function resizeAllCharts() {
        Object.values(charts).forEach(c => c && c.resize());
      }

      // ===== Query context (header info block) =====
      function renderQueryContext() {
        const q = REPORT.query_spec || {};
        const total_families = metric("headline_total_families");
        const total_applicants = metric("headline_total_applicants");
        const total_jurisdictions = metric("headline_total_jurisdictions");

        // Subtitle: a one-line description of the search
        let subtitle = "";
        if (q.mode === "bigquery") {
          const cpcs = (q.cpc_prefixes || []).join(", ");
          const dr = REPORT.date_range || [];
          const span = (dr.length === 2 && dr[0] && dr[1])
            ? (dr[0] === dr[1] ? dr[0] : dr[0] + "\u2013" + dr[1])
            : "";
          subtitle = (cpcs ? "CPC " + cpcs : "") + (span ? " \u00b7 " + span : "");
        } else if (q.mode === "csv") {
          subtitle = "CSV import \u00b7 " + (q.source_file_name || "unknown");
        }
        document.getElementById("report-subtitle").textContent = subtitle || "";

        // Left block: what was searched
        const searchBlock = document.getElementById("qc-search");
        const searchRows = [["Data source", escapeHtml(REPORT.data_source || "unknown")]];
        if (q.mode === "bigquery") {
          const cpcs = (q.cpc_prefixes || []);
          if (cpcs.length) {
            const lines = cpcs.map(function(code) {
              return "<code>" + escapeHtml(code) + "</code>";
            }).join(" ");
            searchRows.push(["CPC codes", lines]);
          }
          if (q.date_from && q.date_to) {
            searchRows.push(["Requested window", escapeHtml(q.date_from) + " to " + escapeHtml(q.date_to)]);
          }
          const countries = q.countries || [];
          if (countries.length) {
            searchRows.push(["Jurisdictions searched", countries.map(escapeHtml).join(", ")]);
          } else {
            searchRows.push(["Jurisdictions searched", "Worldwide"]);
          }
        } else if (q.mode === "csv") {
          searchRows.push(["Source file", "<code>" + escapeHtml(q.source_file_name || "") + "</code>"]);
        }
        searchBlock.innerHTML =
          "<div class='qc-block-title'>Search parameters</div>" +
          searchRows.map(function(r) {
            return "<div class='qc-row'><dt>" + r[0] + "</dt><dd>" + r[1] + "</dd></div>";
          }).join("");

        // Right block: results summary
        const resultsBlock = document.getElementById("qc-results");
        const dr = REPORT.date_range || [];
        const actualSpan = (dr.length === 2 && dr[0] && dr[1])
          ? (dr[0] === dr[1] ? String(dr[0]) : dr[0] + "\u2013" + dr[1])
          : "\u2014";
        const resultsRows = [
          ["Patent families", total_families ? formatInt(total_families.value) : "\u2014"],
          ["Distinct applicants", total_applicants ? formatInt(total_applicants.value) : "\u2014"],
          ["Jurisdictions with filings", total_jurisdictions ? formatInt(total_jurisdictions.value) : "\u2014"],
          ["Effective date span", escapeHtml(actualSpan)],
          ["Records pulled", formatInt(REPORT.record_count || 0)],
          ["Generated", escapeHtml(REPORT.generated_at ? REPORT.generated_at.slice(0, 19).replace("T", " ") + " UTC" : "")],
        ];
        resultsBlock.innerHTML =
          "<div class='qc-block-title'>Results</div>" +
          resultsRows.map(function(r) {
            return "<div class='qc-row'><dt>" + r[0] + "</dt><dd>" + r[1] + "</dd></div>";
          }).join("");
      }

      // ===== Headline =====
      function renderHeadline() {
        const summary = metric("headline_summary");
        if (summary && summary.value) {
          // Pull narrative into the hero block. If the summary has multiple
          // lines (bullets), keep them — the CSS uses white-space: pre-line.
          document.getElementById("hero-narrative").textContent = summary.value;
        }
        setStat("stat-families", metric("headline_total_families"));
        setStat("stat-applicants", metric("headline_total_applicants"));
        setStat("stat-jurisdictions", metric("headline_total_jurisdictions"));
        setStat("stat-peak", metric("headline_peak_year"));
      }
      function setStat(elId, m) {
        if (!m) return;
        const v = m.value;
        document.getElementById(elId).textContent = formatInt(v);
      }

      // ===== Top Applicants bar chart =====
      function initTopApplicants() {
        const m = metric("top_applicants");
        if (!m || !m.value || !m.value.length) return;
        const rows = m.value.slice().reverse(); // bottom-to-top for ECharts horizontal bars
        const chart = echarts.init(document.getElementById("chart-top-applicants"));
        chart.setOption(Object.assign({}, commonChartOptions("Top applicants by patent families"), {
          tooltip: {
            trigger: "item",
            backgroundColor: "#ffffff",
            borderColor: THEME.border,
            borderWidth: 1,
            textStyle: { color: THEME.textPrimary, fontSize: 12 },
            padding: [8, 12],
            formatter: function(params) {
              const idx = params.dataIndex;
              const row = rows[idx];
              return "<b>" + escapeHtml(row.name) + "</b><br>" +
                     row.family_count + " families (" + row.share_label + ")";
            }
          },
          grid: { top: 30, left: 8, right: 80, bottom: 30, containLabel: true },
          xAxis: Object.assign({ type: "value", minInterval: 1 }, baseAxisStyle()),
          yAxis: Object.assign({
            type: "category",
            data: rows.map(r => r.name),
            axisLabel: { color: THEME.textPrimary, fontSize: 13, fontWeight: 500, width: 260, overflow: "truncate" },
          }, { axisLine: { show: false }, axisTick: { show: false } }),
          series: [{
            type: "bar",
            data: rows.map(function(r, i) {
              // Gradient: deeper color for higher-ranked bars
              const intensity = 0.6 + (i / Math.max(rows.length - 1, 1)) * 0.4;
              return {
                value: r.family_count,
                itemStyle: {
                  color: new echarts.graphic.LinearGradient(0, 0, 1, 0, [
                    { offset: 0, color: "#0062b8" },
                    { offset: 1, color: "#4ea5e0" },
                  ]),
                  borderRadius: [0, 6, 6, 0],
                  opacity: intensity,
                },
              };
            }),
            barWidth: 20,
            label: {
              show: true,
              position: "right",
              color: "#0062b8",
              fontSize: 12,
              fontWeight: 700,
            },
          }],
        }));
        chart.on("click", function(params) {
          const row = rows[params.dataIndex];
          if (row) openDrillDown({
            title: row.name,
            subtitle: row.family_count + " patent families (" + row.share_label + ")",
            recordIds: row.record_ids,
          });
        });
        charts.top_applicants = chart;
      }

      // ===== World map =====
      // EPC (European Patent Convention) member states. If the landscape has
      // EPO filings in the regional callouts, we overlay these country names
      // with a distinctive tint so the reader sees "Europe is covered by EPO
      // even though individual EPC countries have no direct filings here".
      // Names match the bundled Natural Earth 1:110m GeoJSON.
      const EPC_MEMBER_STATES = [
        "Germany", "France", "United Kingdom", "Italy", "Spain", "Netherlands",
        "Belgium", "Switzerland", "Sweden", "Austria", "Denmark", "Finland",
        "Norway", "Poland", "Czech Republic", "Portugal", "Ireland", "Greece",
        "Hungary", "Romania", "Bulgaria", "Croatia", "Slovakia", "Slovenia",
        "Lithuania", "Latvia", "Estonia", "Luxembourg", "Iceland", "Turkey",
        "Republic of Serbia", "Macedonia", "Albania"
      ];

      function initWorldMap() {
        const el = document.getElementById("chart-world-map");
        if (!el) return;
        const mapData = REPORT.map_data || [];
        const maxValue = mapData.reduce((m, d) => Math.max(m, d.value), 0);

        // If the landscape has EPO in the regional callouts, build an EPC
        // overlay — all EPC member states get a pale teal fill even if they
        // have no direct country-level filings in the data. This tells the
        // reader "EP filings cover these countries via the EPO route".
        //
        // Implementation: we merge the EPC countries into the mapData array
        // as data items with explicit per-item itemStyle. ECharts' data-item
        // itemStyle has higher precedence than both series-level itemStyle
        // and visualMap coloring, which makes this the most reliable place
        // to apply the overlay.
        const callouts = REPORT.regional_callouts || [];
        const hasEPO = callouts.some(function(c) { return c.code === "EP"; });
        const directFilingNames = new Set(mapData.map(function(d) { return d.name; }));
        const epcData = (hasEPO ? EPC_MEMBER_STATES : [])
          .filter(function(name) { return !directFilingNames.has(name); })
          .map(function(name) {
            return {
              name: name,
              // Sentinel value that is outside the visualMap range so it
              // doesn't pick up the filings color ramp. ECharts still accepts
              // the entry and applies itemStyle from the data item.
              value: NaN,
              isEPC: true,
              itemStyle: {
                areaColor: "#5eead4",  // brighter teal — unmistakable on the map
                borderColor: "#0d9488",
                borderWidth: 0.9,
              },
              emphasis: {
                itemStyle: { areaColor: "#14b8a6", borderColor: "#0f172a", borderWidth: 1.2 },
              },
            };
          });
        const combinedMapData = mapData.concat(epcData);

        const chart = echarts.init(el);
        chart.setOption({
          tooltip: {
            trigger: "item",
            backgroundColor: "#ffffff",
            borderColor: THEME.border,
            borderWidth: 1,
            textStyle: { color: THEME.textPrimary, fontSize: 13 },
            padding: [10, 14],
            formatter: function(params) {
              const d = params.data;
              // EPC member state — rendered via combined map data with isEPC flag
              if (d && d.isEPC) {
                const epoCallout = callouts.find(function(c) { return c.code === "EP"; });
                const epoCount = epoCallout ? formatInt(epoCallout.count) : "";
                return "<b>" + escapeHtml(params.name) + "</b><br>" +
                       "<span style='color:#0d9488;font-weight:600'>EPC member state</span><br>" +
                       "<span style='color:#94a3b8;font-size:12px'>Covered by " + epoCount + " EPO filings \u2014 see map footnote</span>";
              }
              // Actual country filings — must be a real numeric value
              if (d && typeof d.value === "number" && !isNaN(d.value)) {
                return "<b>" + escapeHtml(d.displayName || params.name) + "</b><br>" +
                       formatInt(d.value) + " filings (" + (d.share_label || "") + ")";
              }
              // Fallback for no-data countries
              return "<b>" + escapeHtml(params.name) + "</b><br><span style='color:#a0aec0'>No filings in this landscape</span>";
            },
          },
          visualMap: {
            left: 12, bottom: 12,
            min: 0, max: maxValue || 1,
            text: ["More", "Fewer"],
            textStyle: { color: THEME.textMuted, fontSize: 11, fontWeight: 600 },
            itemWidth: 14,
            itemHeight: 110,
            inRange: {
              color: ["#ccfbf1", "#99f6e4", "#5eead4", "#2dd4bf", "#14b8a6", "#0d9488", "#115e59"],
            },
            calculable: false,
          },
          series: [{
            type: "map",
            map: "world",
            roam: false,
            data: combinedMapData,
            itemStyle: {
              areaColor: THEME.mapEmpty,
              borderColor: THEME.mapBorder,
              borderWidth: 0.5,
            },
            emphasis: {
              itemStyle: { areaColor: "#fbbf24", borderColor: "#0f172a", borderWidth: 1 },
              label: { show: false },
            },
            select: { disabled: true },
            label: { show: false },
          }],
        });
        chart.on("click", function(params) {
          const d = params.data;
          // Direct country filings — drill into the list for that country
          if (d && typeof d.value === "number" && !isNaN(d.value) && d.record_ids && d.record_ids.length) {
            openDrillDown({
              title: d.displayName || params.name,
              subtitle: d.value + " filings",
              recordIds: d.record_ids,
            });
            return;
          }
          // EPC member state — route to the EPO drill-down so the user sees the
          // EPO patents that notionally cover this country.
          if (d && d.isEPC) {
            const epoCallout = callouts.find(function(c) { return c.code === "EP"; });
            if (epoCallout) {
              openDrillDown({
                title: "European Patent Office (EPO)",
                subtitle: params.name + " is an EPC member state \u00b7 " +
                  formatInt(epoCallout.count) + " EPO filings cover this jurisdiction (" + epoCallout.share_label + ")",
                recordIds: epoCallout.record_ids || [],
              });
            }
            return;
          }
        });
        charts.world_map = chart;
      }

      // ===== Regional office footnote =====
      // Regional offices (EPO, WIPO) aren't on the map because they cover
      // many countries, not one. Rather than a permanent sidebar, they live
      // as a compact footnote immediately below the map.
      function renderRegionalCallouts() {
        const container = document.getElementById("regional-callouts");
        const callouts = REPORT.regional_callouts || [];
        if (!callouts.length) {
          container.style.display = "none";
          return;
        }
        const items = callouts.map(function(c) {
          return "<span class='map-footnote-item' data-code='" + escapeHtml(c.code) + "' title='" + escapeHtml(c.note || '') + "'>" +
            "<span class='count'>" + formatInt(c.count) + "</span>" +
            "<span>filings at <strong>" + escapeHtml(c.name) + "</strong></span>" +
          "</span>";
        }).join("");
        container.innerHTML =
          "<span class='map-footnote-label'>Additional filings not plotted</span>" +
          items +
          "<span class='map-footnote-help'>Regional offices cover multiple countries \u2014 click for details</span>";
        container.querySelectorAll(".map-footnote-item").forEach(function(el) {
          el.addEventListener("click", function() {
            const code = el.dataset.code;
            const c = callouts.find(function(x) { return x.code === code; });
            if (c) openDrillDown({
              title: c.name,
              subtitle: c.count + " filings (" + c.share_label + ")",
              recordIds: c.record_ids,
            });
          });
        });
      }

      // ===== Jurisdiction bars =====
      function initJurisdictionBars() {
        const m = metric("jurisdiction_distribution");
        if (!m || !m.value || !m.value.length) return;
        const rows = m.value.slice().reverse();
        const chart = echarts.init(document.getElementById("chart-jurisdiction-bars"));
        chart.setOption(Object.assign({}, commonChartOptions(null), {
          tooltip: {
            trigger: "item",
            backgroundColor: "#ffffff",
            borderColor: THEME.border,
            borderWidth: 1,
            textStyle: { color: THEME.textPrimary, fontSize: 12 },
            padding: [8, 12],
            formatter: function(params) {
              const row = rows[params.dataIndex];
              const regional = row.is_regional ? " <span style='color:#a0aec0'>(regional)</span>" : "";
              return "<b>" + escapeHtml(row.name) + "</b>" + regional + "<br>" +
                row.count + " filings (" + row.share_label + ")";
            },
          },
          grid: { top: 10, left: 8, right: 80, bottom: 30, containLabel: true },
          xAxis: Object.assign({ type: "value", minInterval: 1 }, baseAxisStyle()),
          yAxis: Object.assign({
            type: "category",
            data: rows.map(r => r.name + (r.is_regional ? " (regional)" : "")),
            axisLabel: { color: THEME.textPrimary, fontSize: 13, fontWeight: 500, width: 240, overflow: "truncate" },
          }, { axisLine: { show: false }, axisTick: { show: false } }),
          series: [{
            type: "bar",
            data: rows.map(function(r, i) {
              // Teal gradient for geography section
              const intensity = 0.6 + (i / Math.max(rows.length - 1, 1)) * 0.4;
              return {
                value: r.count,
                itemStyle: {
                  color: new echarts.graphic.LinearGradient(0, 0, 1, 0, [
                    { offset: 0, color: "#0d9488" },
