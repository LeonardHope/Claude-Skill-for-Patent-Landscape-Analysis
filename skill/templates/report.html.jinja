            itemStyle: { borderRadius: [0, 6, 6, 0] },
            barWidth: 18,
            label: { show: true, position: "right", color: "#0d9488", fontSize: 12, fontWeight: 700 },
          }],
        }));
        chart.on("click", function(params) {
          const row = rows[params.dataIndex];
          if (row) openDrillDown({
            title: row.name,
            subtitle: row.count + " filings (" + row.share_label + ")",
            recordIds: row.record_ids,
          });
        });
        charts.jurisdiction_bars = chart;
      }

