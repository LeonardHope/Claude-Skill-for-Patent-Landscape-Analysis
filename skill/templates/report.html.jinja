      // ===== Document type breakdown (methodology) =====
      function renderDocTypes() {
        const m = metric("document_type_breakdown");
        const container = document.getElementById("method-doctypes");
        if (!m || !m.value || !m.value.length) {
          container.innerHTML = "<p class='section-subtitle' style='font-size:13px'>(no kind-code data available)</p>";
          return;
        }
        container.innerHTML = "<div class='doctype-grid'>" +
          m.value.map(function(r) {
            return "<div class='doctype-pill' data-kind='" + escapeHtml(r.label) + "'>" +
              "<div class='doctype-label'>" + escapeHtml(r.label) + "</div>" +
              "<div class='doctype-count'>" + formatInt(r.count) + "</div>" +
              "<div class='doctype-share'>" + r.share_pct.toFixed(1) + "%</div>" +
            "</div>";
          }).join("") +
          "</div>";
      }

      // ===== Methodology =====
      function renderMethodology() {
        const q = REPORT.query_spec || {};
        const queryParts = [];
        if (q.cpc_prefixes && q.cpc_prefixes.length) {
          queryParts.push("CPC prefixes: " + q.cpc_prefixes.map(function(p) {
            return "<code>" + escapeHtml(p) + "</code>";
          }).join(", "));
        }
        if (q.countries && q.countries.length) {
          queryParts.push("Countries: " + q.countries.join(", "));
        }
        if (q.keywords && q.keywords.length) {
          queryParts.push("Keywords: " + q.keywords.join(", "));
        }
        if (q.source_file_name) {
          queryParts.push("Source file: <code>" + escapeHtml(q.source_file_name) + "</code>");
        }
        document.getElementById("method-query").innerHTML =
          queryParts.length ? queryParts.join("<br>") : "No query spec recorded.";

        document.getElementById("method-source").textContent = REPORT.data_source || "unknown";
        document.getElementById("method-dates").textContent =
          (REPORT.date_range && REPORT.date_range.length === 2)
            ? REPORT.date_range[0] + "\u2013" + REPORT.date_range[1]
            : "unknown";

        const caveats = (REPORT.query_spec && REPORT.query_spec.caveats) || REPORT.caveats || [];
        const caveatList = document.getElementById("method-caveats");
        if (caveats.length) {
          caveatList.innerHTML = caveats.map(function(c) {
            return "<li>" + escapeHtml(c) + "</li>";
          }).join("");
        } else {
          caveatList.innerHTML = "<li>No additional caveats recorded.</li>";
        }

        // Merge audit
        const mergeBlock = document.getElementById("merges-block");
        const mergeList = document.getElementById("merge-list");
        const merges = REPORT.applicant_merges || {};
        const merged = Object.keys(merges).filter(function(k) { return merges[k].length > 1; });
        if (!merged.length) {
          mergeBlock.classList.add("hidden");
          return;
        }
        mergeList.innerHTML = merged.sort().map(function(canonical) {
          const variants = merges[canonical];
          return "<div class='merge-item'>" +
            "<div class='merge-canonical'>" + escapeHtml(canonical) + "</div>" +
            "<div class='merge-variants'>" + variants.map(escapeHtml).join(" &middot; ") + "</div>" +
          "</div>";
        }).join("");
      }

      // ===== Receipts / drill-down panel =====
      function openReceipts(metricId) {
        const m = metric(metricId);
        if (!m) return;
        document.getElementById("panel-title").textContent = m.label || "Receipts";
        let html = "";

        html += "<div class='panel-label'>Value</div>";
        html += "<div class='panel-text'>" + escapeHtml(typeof m.value === "object" ? JSON.stringify(m.value).slice(0, 100) + "..." : String(m.value)) + "</div>";

        if (m.quantification && Object.keys(m.quantification).length) {
          html += "<div class='panel-label'>Breakdown</div>";
          html += "<dl class='panel-quant'>";
          for (const [k, v] of Object.entries(m.quantification)) {
            html += "<dt>" + escapeHtml(k.replace(/_/g, " ")) + "</dt>";
            html += "<dd>" + escapeHtml(typeof v === "number" ? v.toLocaleString() : String(v)) + "</dd>";
          }
          html += "</dl>";
        }

        if (m.formula_plain) {
          html += "<div class='panel-label'>How this was computed</div>";
          html += "<div class='panel-text'>" + escapeHtml(m.formula_plain) + "</div>";
        }
        if (m.formula_technical) {
          html += "<div class='panel-label'>Technical formula</div>";
          html += "<div class='panel-formula'>" + escapeHtml(m.formula_technical) + "</div>";
        }

        if (m.source_record_ids && m.source_record_ids.length) {
          html += "<div class='panel-label'>Source records (" + m.source_record_ids.length + ")</div>";
          html += "<div class='panel-records'>";
          html += m.source_record_ids.slice(0, 100).map(function(rid) {
            const rec = recordById[rid];
            if (rec && rec.url) {
              return "<div class='panel-record'>" +
                "<a href='" + escapeHtml(rec.url) + "' target='_blank' rel='noopener' class='panel-record-title'>" +
                escapeHtml(rec.publication_number || rid) + "</a>" +
                "<span class='panel-record-meta'>" + escapeHtml(rec.jurisdiction || "") + " &middot; " + (rec.application_year || "\u2014") + "</span>" +
              "</div>";
            } else if (rec) {
              return "<div class='panel-record'>" +
                "<span class='panel-record-title'>" + escapeHtml(rec.publication_number || rid) + "</span>" +
                "<span class='panel-record-meta'>" + escapeHtml(rec.jurisdiction || "") + " &middot; " + (rec.application_year || "\u2014") + "</span>" +
              "</div>";
            }
            return "<div class='panel-record'><span class='panel-record-title'>" + escapeHtml(rid) + "</span></div>";
          }).join("");
          if (m.source_record_ids.length > 100) {
            html += "<div class='panel-record-meta' style='padding:8px 10px'>(showing first 100 of " + m.source_record_ids.length + ")</div>";
          }
          html += "</div>";
        }

        if (m.caveats && m.caveats.length) {
          html += "<div class='panel-label'>Caveats</div>";
          html += "<ul class='panel-caveats'>" + m.caveats.map(function(c) {
            return "<li>" + escapeHtml(c) + "</li>";
          }).join("") + "</ul>";
        }

        if (m.sensitivity_notes && m.sensitivity_notes.length) {
          html += "<div class='panel-label'>What would change this</div>";
          html += "<ul class='panel-caveats'>" + m.sensitivity_notes.map(function(c) {
            return "<li>" + escapeHtml(c) + "</li>";
          }).join("") + "</ul>";
        }

        document.getElementById("panel-body").innerHTML = html;
        showPanel();
      }

      function openDrillDown(opts) {
        document.getElementById("panel-title").textContent = opts.title || "Details";
        let html = "";
        if (opts.subtitle) {
          html += "<div class='panel-text' style='margin-bottom:18px'>" + escapeHtml(opts.subtitle) + "</div>";
        }
        if (opts.recordIds && opts.recordIds.length) {
          // Group records by first normalized applicant
          const groups = {};
          const orphans = [];
          let resolvable = 0;
          for (const rid of opts.recordIds) {
            const rec = recordById[rid];
            if (!rec) { orphans.push(rid); continue; }
            resolvable++;
            const applicant = (rec.applicants && rec.applicants[0]) || "Unknown applicant";
            (groups[applicant] = groups[applicant] || []).push(rec);
          }
          const ranked = Object.keys(groups).sort(function(a, b) {
            return groups[b].length - groups[a].length || a.localeCompare(b);
          });

          html += "<div class='panel-label'>By applicant (" + ranked.length + " applicants, " +
                  (resolvable + orphans.length) + " patents)</div>";

          // All applicant groups collapsed by default. The user clicks to expand.
          const MAX_EXPANDED = 0;
          html += ranked.map(function(name, i) {
            const rows = groups[name];
            const isOpen = i < MAX_EXPANDED ? " open" : "";
            const patentHtml = rows.slice(0, 50).map(function(rec) {
              const link = rec.url
                ? "<a href='" + escapeHtml(rec.url) + "' target='_blank' rel='noopener' class='panel-record-title' title='" + escapeHtml(rec.title || "") + "'>" +
                  escapeHtml(rec.publication_number || "") + "</a>"
                : "<span class='panel-record-title'>" + escapeHtml(rec.publication_number || "") + "</span>";
              return "<div class='panel-record'>" + link +
                "<span class='panel-record-meta'>" + escapeHtml(rec.jurisdiction || "") + " \u00b7 " + (rec.application_year || "\u2014") + "</span>" +
              "</div>";
            }).join("");
            const more = rows.length > 50
              ? "<div class='panel-record-meta' style='padding:6px 10px'>(showing first 50 of " + rows.length + ")</div>"
              : "";
            return "<details class='panel-applicant-group'" + isOpen + ">" +
              "<summary>" +
                "<span class='panel-applicant-name'>" + escapeHtml(name) + "</span>" +
                "<span style='display:flex;align-items:center;gap:4px'>" +
                  "<span class='panel-applicant-count'>" + rows.length + "</span>" +
                  "<span class='panel-applicant-disclosure'>\u25B6</span>" +
                "</span>" +
              "</summary>" +
              "<div style='padding:4px'>" + patentHtml + more + "</div>" +
            "</details>";
          }).join("");

          if (orphans.length) {
            html += "<div class='panel-label'>Unresolved record IDs (" + orphans.length + ")</div>";
            html += "<div class='panel-text' style='font-size:12px'>" +
              "These records were referenced by metric aggregates but not embedded in this file. " +
              "Use the CSV download for the complete dataset." +
              "</div>";
          }
        }
        document.getElementById("panel-body").innerHTML = html;
        // Always scroll the panel body to the top when opening new content
        document.getElementById("panel-body").scrollTop = 0;
        showPanel();
      }

      function showPanel() {
        document.getElementById("panel-overlay").classList.add("visible");
        document.getElementById("receipts-panel").classList.add("visible");
      }
      function closePanel() {
        document.getElementById("panel-overlay").classList.remove("visible");
        document.getElementById("receipts-panel").classList.remove("visible");
      }

      function wireUpPanelEvents() {
        document.getElementById("panel-overlay").addEventListener("click", closePanel);
        document.getElementById("panel-close-btn").addEventListener("click", closePanel);
        document.addEventListener("keydown", function(e) {
          if (e.key === "Escape") closePanel();
        });
        document.querySelectorAll("[data-metric]").forEach(function(el) {
          el.addEventListener("click", function() {
            openReceipts(el.dataset.metric);
          });
        });
      }

      // ===== Export menus =====
      function wireUpExportMenus() {
        document.querySelectorAll("[data-export-toggle]").forEach(function(btn) {
          btn.addEventListener("click", function(e) {
            e.stopPropagation();
            const parent = btn.closest(".export-dropdown");
            document.querySelectorAll(".export-dropdown.open").forEach(function(d) {
              if (d !== parent) d.classList.remove("open");
            });
            parent.classList.toggle("open");
          });
        });
        document.addEventListener("click", function() {
          document.querySelectorAll(".export-dropdown.open").forEach(function(d) {
            d.classList.remove("open");
          });
        });
        document.querySelectorAll("[data-chart][data-format]").forEach(function(btn) {
          btn.addEventListener("click", function() {
            const chartId = btn.dataset.chart;
            const format = btn.dataset.format;
            const chart = charts[chartId];
            if (!chart) return;
            const url = chart.getDataURL({
              type: format,
              backgroundColor: "#ffffff",
              pixelRatio: 3,
              excludeComponents: ["toolbox"],
            });
            const link = document.createElement("a");
            link.download = chartId + "." + format;
            link.href = url;
            link.click();
          });
        });
      }

      // ===== Download menu (CSV + Print) =====
      function wireUpDownloadMenu() {
        const dropdown = document.getElementById("download-dropdown");
        const btn = document.getElementById("download-btn");
        const menu = document.getElementById("download-menu");
        if (!btn || !menu) return;
        btn.addEventListener("click", function(e) {
          e.stopPropagation();
          dropdown.classList.toggle("open");
        });
        document.addEventListener("click", function(e) {
          if (!dropdown.contains(e.target)) dropdown.classList.remove("open");
        });
        menu.querySelectorAll("button[data-action]").forEach(function(b) {
          b.addEventListener("click", function() {
            const action = b.dataset.action;
            dropdown.classList.remove("open");
            if (action === "download-html") downloadHTML();
            else if (action === "download-csv") downloadCSV();
            else if (action === "print-pdf") window.print();
          });
        });
      }

      function downloadHTML() {
        // Save a fresh copy of the current HTML document as a standalone file.
        // This is the same deliverable the user is already viewing — they can
        // email it, archive it, or save it to a project folder.
        const doctype = "<!doctype html>\n";
        const html = doctype + document.documentElement.outerHTML;
        const blob = new Blob([html], { type: "text/html;charset=utf-8" });
        const url = URL.createObjectURL(blob);
        const link = document.createElement("a");
        link.href = url;
        const titleEl = document.querySelector(".report-title-block h1");
        const slug = (titleEl ? titleEl.textContent : "patent-landscape")
          .replace(/[^a-zA-Z0-9]+/g, "-")
          .replace(/^-|-$/g, "")
          .toLowerCase()
          .slice(0, 60);
        link.download = `${slug}.html`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        URL.revokeObjectURL(url);
      }

      function downloadCSV() {
        // Build a CSV from the embedded records + metrics data.
        // Fields chosen for defensibility: the same fields a patent attorney would
        // include in a deliverable spreadsheet.
        const records = REPORT.records || [];
        if (!records.length) return;
        const header = [
          "publication_number", "title", "jurisdiction",
          "application_year", "priority_year", "applicants", "url"
        ];
        const rows = [header.join(",")];
        for (const r of records) {
          const applicants = (r.applicants || []).join("; ");
          const row = [
            r.publication_number || "",
            r.title || "",
            r.jurisdiction || "",
            r.application_year || "",
            r.priority_year || "",
            applicants,
            r.url || "",
          ].map(csvEscape).join(",");
          rows.push(row);
        }
        const csvContent = rows.join("\r\n");
        const blob = new Blob([csvContent], { type: "text/csv;charset=utf-8" });
        const url = URL.createObjectURL(blob);
        const link = document.createElement("a");
        link.href = url;
        const slug = (REPORT.query_spec && REPORT.query_spec.source_label || "patent-landscape")
          .replace(/[^a-zA-Z0-9]+/g, "_").toLowerCase().slice(0, 60);
        link.download = `patent-landscape_${slug}_${records.length}-records.csv`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        URL.revokeObjectURL(url);
      }

      function csvEscape(value) {
        if (value == null) return "";
        const s = String(value);
        if (/[,"\r\n]/.test(s)) {
          return '"' + s.replace(/"/g, '""') + '"';
        }
        return s;
      }

      // ================================================================
      // CLIENT-SIDE ANALYTICS ENGINE — interactive document-type filter
      // ================================================================
      // When the user toggles a filter pill, ALL metrics recompute from
      // the full embedded record set, then every chart re-renders via
      // setOption. This mirrors the Python analytics module in JS.

      // Expand abbreviated record keys to readable names (once, on load)
      const ALL_RECORDS = (REPORT.records || []).map(function(r) {
        return {
          publication_number: r.p || "",
          title: r.t || "",
          jurisdiction: r.j || "",
          application_year: r.y || 0,
          kind_code: r.k || "",
          family_id: r.f || r.p || "",
          applicants: r.a || [],
          cpc_classes: r.c || [],
          cited_by_count: r.ci || 0,
          url: r.u || "",
        };
      });
      const TOTAL_RECORD_COUNT = ALL_RECORDS.length;

      function classifyDocType(kindCode) {
        if (!kindCode) return "Unknown";
        var k = kindCode.toUpperCase();
        if (k.charAt(0) === "U" || k.charAt(0) === "Y") return "Utility model";
        if (k.charAt(0) === "B") return "Granted patent";
        if (k.charAt(0) === "A") return "Patent application";
        if (k.charAt(0) === "S" || k.charAt(0) === "D") return "Design patent";
        if (k.charAt(0) === "P") return "Plant patent";
        return "Other";
      }

      // Classify every record once
      ALL_RECORDS.forEach(function(r) {
        r._docType = classifyDocType(r.kind_code);
        recordById[r.publication_number] = r;
      });

      // Count doc types for the filter pills
      function countDocTypes(records) {
        var counts = {};
        records.forEach(function(r) {
          counts[r._docType] = (counts[r._docType] || 0) + 1;
        });
        return counts;
      }

      // Filing year (matches Python: application_year fallback to 0)
      function filingYear(r) { return r.application_year || 0; }

      // Family dedup: pick one record per family_id (earliest filing year)
      function familyReps(records) {
        var byFamily = {};
        records.forEach(function(r) {
          var fid = r.family_id;
          var existing = byFamily[fid];
          if (!existing || filingYear(r) < filingYear(existing)) {
            byFamily[fid] = r;
          }
        });
        return Object.values(byFamily);
      }

      // ---- Metric computations (mirrors analytics.py) ----

      function computeTopApplicants(records, topN) {
        topN = topN || 15;
        var reps = familyReps(records);
        var total = reps.length;
        var counts = {};
        var recIds = {};
        reps.forEach(function(r) {
          r.applicants.forEach(function(a) {
            if (!a) return;
            counts[a] = (counts[a] || 0) + 1;
            (recIds[a] = recIds[a] || []).push(r.publication_number);
          });
        });
        var ranked = Object.keys(counts).sort(function(a, b) {
          return counts[b] - counts[a] || a.localeCompare(b);
        }).slice(0, topN);
        return ranked.map(function(name, i) {
          return {
            rank: i + 1, name: name,
            family_count: counts[name],
            share_pct: total ? Math.round(counts[name] / total * 1000) / 10 : 0,
            share_label: total ? (counts[name] / total * 100).toFixed(1) + "%" : "0%",
            record_ids: (recIds[name] || []).slice(0, 200),
          };
        });
      }

      function computeJurisdictionDistribution(records) {
        var counts = {};
        var recIds = {};
        records.forEach(function(r) {
          if (!r.jurisdiction) return;
          counts[r.jurisdiction] = (counts[r.jurisdiction] || 0) + 1;
          (recIds[r.jurisdiction] = recIds[r.jurisdiction] || []).push(r.publication_number);
        });
        var total = records.length;
        var ranked = Object.keys(counts).sort(function(a, b) {
          return counts[b] - counts[a] || a.localeCompare(b);
        });
        var REGIONAL = {EP:1, WO:1, EA:1, AP:1, OA:1, GC:1};
        return ranked.map(function(code) {
          return {
            code: code, name: code, is_regional: !!REGIONAL[code],
            count: counts[code],
            share_pct: total ? Math.round(counts[code] / total * 1000) / 10 : 0,
            share_label: total ? (counts[code] / total * 100).toFixed(1) + "%" : "0%",
            record_ids: (recIds[code] || []).slice(0, 200),
          };
        });
      }

      function computeFilingTrends(records) {
        var reps = familyReps(records);
        var yearCounts = {};
        reps.forEach(function(r) {
          var y = filingYear(r);
          if (y) yearCounts[y] = (yearCounts[y] || 0) + 1;
        });
        var years = Object.keys(yearCounts).map(Number).sort();
        return { years: years, counts: years.map(function(y) { return yearCounts[y]; }) };
      }

      function computeTechAreas(records, topN) {
        topN = topN || 15;
        var reps = familyReps(records);
        var total = reps.length;
        var classFamilies = {};
        var classRecIds = {};
        reps.forEach(function(r) {
          var seen = {};
          r.cpc_classes.forEach(function(cls) {
            if (!cls || seen[cls]) return;
            seen[cls] = true;
            classFamilies[cls] = (classFamilies[cls] || 0) + 1;
            (classRecIds[cls] = classRecIds[cls] || []).push(r.publication_number);
          });
        });
        var ranked = Object.keys(classFamilies).sort(function(a, b) {
          return classFamilies[b] - classFamilies[a] || a.localeCompare(b);
        }).slice(0, topN);
        // CPC plain English lookup — use the Python-computed metric as reference
        var origTech = (metric("technology_areas") || {}).value || [];
        var cpcLookup = {};
        origTech.forEach(function(row) { cpcLookup[row.code] = row.name; });
        return ranked.map(function(code) {
          return {
            code: code,
            name: cpcLookup[code] || code,
            family_count: classFamilies[code],
            share_pct: total ? Math.round(classFamilies[code] / total * 1000) / 10 : 0,
            share_label: total ? (classFamilies[code] / total * 100).toFixed(1) + "%" : "0%",
            record_ids: (classRecIds[code] || []).slice(0, 200),
          };
        });
      }

      // Spotlight views for Notable Patents
      function computeSpotlight(records, view) {
        var sorted, criterion;
        if (view === "recent") {
          sorted = records.slice().sort(function(a, b) { return (filingYear(b) || 0) - (filingYear(a) || 0) || a.publication_number.localeCompare(b.publication_number); });
          criterion = "Most recent filings";
        } else if (view === "top-applicant-recent") {
          var topApps = computeTopApplicants(records, 5).map(function(r) { return r.name; });
          var topSet = {};
          topApps.forEach(function(a) { topSet[a] = true; });
          var candidates = records.filter(function(r) {
            return r.applicants.some(function(a) { return topSet[a]; });
          });
          sorted = candidates.sort(function(a, b) { return (filingYear(b) || 0) - (filingYear(a) || 0); });
          criterion = "Top applicants\u2019 newest patents";
        } else if (view === "foundational") {
          sorted = records.slice().sort(function(a, b) { return (filingYear(a) || 9999) - (filingYear(b) || 9999) || a.publication_number.localeCompare(b.publication_number); });
          criterion = "Foundational patents (earliest filings)";
        } else if (view === "cross-disciplinary") {
          sorted = records.slice().sort(function(a, b) { return (b.cpc_classes.length || 0) - (a.cpc_classes.length || 0); });
          criterion = "Cross-disciplinary (most CPC subclasses)";
        } else {
          sorted = records.slice();
          criterion = view;
        }
        var rows = sorted.slice(0, 10).map(function(r, i) {
          return {
            rank: i + 1,
            publication_number: r.publication_number,
            title: r.title || r.publication_number,
            applicant: r.applicants[0] || "",
            jurisdiction: r.jurisdiction,
            year: filingYear(r),
            cited_by_count: r.cited_by_count || 0,
            url: r.url,
            cpc_count: r.cpc_classes.length,
          };
        });
        return { criterion: criterion, rows: rows, has_citations: rows.some(function(r) { return r.cited_by_count > 0; }) };
      }

      // ---- Filter state ----
      var activeDocTypes = null; // null = all active (no filtering)
      var currentSpotlightView = "recent";

      function getFilteredRecords() {
        if (!activeDocTypes) return ALL_RECORDS;
        return ALL_RECORDS.filter(function(r) { return activeDocTypes[r._docType]; });
      }

      // ---- Render filter pills ----
      function renderFilterBar() {
        var allCounts = countDocTypes(ALL_RECORDS);
        var types = Object.keys(allCounts).sort(function(a, b) { return allCounts[b] - allCounts[a]; });
        var pillsEl = document.getElementById("filter-pills");
        pillsEl.innerHTML = types.map(function(type) {
          var isActive = !activeDocTypes || activeDocTypes[type];
          return "<button class='filter-pill" + (isActive ? " active" : "") + "' data-type='" +
            escapeHtml(type) + "'>" + escapeHtml(type) +
            " <span class='pill-count'>(" + allCounts[type].toLocaleString() + ")</span></button>";
        }).join("");

        // Wire click handlers
        pillsEl.querySelectorAll(".filter-pill").forEach(function(pill) {
          pill.addEventListener("click", function() {
            var type = pill.dataset.type;
            // Initialize activeDocTypes if first toggle
            if (!activeDocTypes) {
              activeDocTypes = {};
              types.forEach(function(t) { activeDocTypes[t] = true; });
            }
            activeDocTypes[type] = !activeDocTypes[type];
            // If all toggled off, reset to all on
            if (!Object.values(activeDocTypes).some(Boolean)) {
              activeDocTypes = null;
            }
            refilterAndRender();
          });
        });

        updateFilterSummary();
      }

      function updateFilterSummary() {
        var filtered = getFilteredRecords();
        var summaryEl = document.getElementById("filter-summary");
        var resetEl = document.getElementById("filter-reset");
        if (!activeDocTypes || filtered.length === TOTAL_RECORD_COUNT) {
          summaryEl.innerHTML = "Showing all <strong>" + TOTAL_RECORD_COUNT.toLocaleString() + "</strong> records";
          resetEl.style.display = "none";
        } else {
          summaryEl.innerHTML = "Showing <strong>" + filtered.length.toLocaleString() +
            "</strong> of " + TOTAL_RECORD_COUNT.toLocaleString();
          resetEl.style.display = "inline";
        }
      }

      // ---- Master re-render ----
      function refilterAndRender() {
        var records = getFilteredRecords();

        // Update filter UI
        renderFilterBar();

        // Rebuild the record lookup for drill-downs
        for (var key in recordById) delete recordById[key];
        records.forEach(function(r) { recordById[r.publication_number] = r; });

        // Recompute headline stats
        var reps = familyReps(records);
        var uniqueApplicants = {};
        reps.forEach(function(r) { r.applicants.forEach(function(a) { if (a) uniqueApplicants[a] = true; }); });
        var uniqueJuris = {};
        records.forEach(function(r) { if (r.jurisdiction) uniqueJuris[r.jurisdiction] = true; });
        document.getElementById("stat-families").textContent = reps.length.toLocaleString();
        document.getElementById("stat-applicants").textContent = Object.keys(uniqueApplicants).length.toLocaleString();
        document.getElementById("stat-jurisdictions").textContent = Object.keys(uniqueJuris).length.toLocaleString();
        var yearCounts = {};
        reps.forEach(function(r) { var y = filingYear(r); if (y) yearCounts[y] = (yearCounts[y] || 0) + 1; });
        var peakYear = 0, peakCount = 0;
        Object.keys(yearCounts).forEach(function(y) {
          if (yearCounts[y] > peakCount) { peakYear = +y; peakCount = yearCounts[y]; }
        });
        document.getElementById("stat-peak").textContent = peakYear ? peakYear.toLocaleString() : "\u2014";

        // Re-render top applicants chart
        var topApp = computeTopApplicants(records, 15).reverse();
        if (charts.top_applicants && topApp.length) {
          charts.top_applicants.setOption({
            yAxis: { data: topApp.map(function(r) { return r.name; }) },
            series: [{ data: topApp.map(function(r) {
              return { value: r.family_count, itemStyle: {
                color: new echarts.graphic.LinearGradient(0, 0, 1, 0, [
                  { offset: 0, color: "#0062b8" }, { offset: 1, color: "#4ea5e0" }]),
              }};
            }) }],
          });
          // Rebind click handler
          charts.top_applicants.off("click");
          charts.top_applicants.on("click", function(params) {
            var row = topApp[params.dataIndex];
            if (row) openDrillDown({ title: row.name, subtitle: row.family_count + " families (" + row.share_label + ")", recordIds: row.record_ids });
          });
        }

        // Re-render filing trends
        var trends = computeFilingTrends(records);
        if (charts.filing_trends && trends.years.length) {
          charts.filing_trends.setOption({
            xAxis: { data: trends.years },
            series: [{ data: trends.counts }],
          });
        }

        // Re-render technology areas
        var tech = computeTechAreas(records, 15).reverse();
        if (charts.technology_areas && tech.length) {
          charts.technology_areas.setOption({
            yAxis: { data: tech.map(function(r) { return r.name; }) },
            series: [{ data: tech.map(function(r) {
              return { value: r.family_count, itemStyle: {
                color: new echarts.graphic.LinearGradient(0, 0, 1, 0, [
                  { offset: 0, color: "#7c3aed" }, { offset: 1, color: "#a78bfa" }]),
              }};
            }) }],
          });
          charts.technology_areas.off("click");
          charts.technology_areas.on("click", function(params) {
            var row = tech[params.dataIndex];
            if (row) openDrillDown({ title: row.name + " (" + row.code + ")", subtitle: row.family_count + " families (" + row.share_label + ")", recordIds: row.record_ids });
          });
        }

        // Re-render jurisdiction bars
        var juris = computeJurisdictionDistribution(records).reverse();
        if (charts.jurisdiction_bars && juris.length) {
          charts.jurisdiction_bars.setOption({
            yAxis: { data: juris.map(function(r) { return r.name + (r.is_regional ? " (regional)" : ""); }) },
            series: [{ data: juris.map(function(r) {
              return { value: r.count, itemStyle: {
                color: new echarts.graphic.LinearGradient(0, 0, 1, 0, [
                  { offset: 0, color: "#0d9488" }, { offset: 1, color: "#14b8a6" }]),
              }};
            }) }],
          });
          charts.jurisdiction_bars.off("click");
          charts.jurisdiction_bars.on("click", function(params) {
            var row = juris[params.dataIndex];
            if (row) openDrillDown({ title: row.name, subtitle: row.count + " filings (" + row.share_label + ")", recordIds: row.record_ids });
          });
        }

        // Re-render notable/spotlight
        refilterSpotlight();
      }

      function refilterSpotlight() {
        var records = getFilteredRecords();
        var data = computeSpotlight(records, currentSpotlightView);
        document.getElementById("notable-criterion").textContent = "Showing: " + data.criterion;
        var tbody = document.getElementById("notable-tbody");
        var lastColHeader = data.rows.some(function(r) { return r.cpc_count > 0 && currentSpotlightView === "cross-disciplinary"; })
          ? "CPC" : "CITES";
        tbody.innerHTML = data.rows.map(function(row) {
          var link = row.url
            ? "<a href='" + escapeHtml(row.url) + "' target='_blank' rel='noopener'>" + escapeHtml(row.publication_number) + "</a>"
            : escapeHtml(row.publication_number);
          var lastCol = currentSpotlightView === "cross-disciplinary" ? row.cpc_count : (row.cited_by_count || 0);
          return "<tr>" +
            "<td class='col-rank'>" + row.rank + "</td>" +
            "<td class='col-title'>" +
              "<div style='font-weight:500'>" + escapeHtml(row.title || row.publication_number) + "</div>" +
              "<div style='font-size:11px;color:#a0aec0;margin-top:2px'>" + link + " \u00b7 " + escapeHtml(row.jurisdiction || "") + "</div>" +
            "</td>" +
            "<td class='col-applicant'>" + escapeHtml(row.applicant || "") + "</td>" +
            "<td class='col-year'>" + (row.year || "\u2014") + "</td>" +
            "<td class='col-count'>" + lastCol + "</td>" +
          "</tr>";
        }).join("");
      }

      // ---- Wire up on load ----
      function wireUpFilterAndSpotlight() {
        renderFilterBar();
        document.getElementById("filter-reset").addEventListener("click", function() {
          activeDocTypes = null;
          refilterAndRender();
        });

        var select = document.getElementById("spotlight-select");
        if (select) {
          select.addEventListener("change", function() {
            currentSpotlightView = select.value;
            refilterSpotlight();
          });
          // Render initial spotlight view
          currentSpotlightView = select.value;
          refilterSpotlight();
        }
      }

      // ===== Utils =====
      function escapeHtml(s) {
        if (s == null) return "";
        return String(s)
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#39;");
      }
    })();
  </script>
</body>
</html>
