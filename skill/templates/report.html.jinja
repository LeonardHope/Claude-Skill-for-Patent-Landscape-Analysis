      // ===== Notable patents table =====
      function renderNotable() {
        const m = metric("notable_patents");
        if (!m || !m.value) return;
        const data = m.value;
        document.getElementById("notable-criterion").textContent = "Criterion: " + data.criterion;
        const tbody = document.getElementById("notable-tbody");
        tbody.innerHTML = data.rows.map(function(row) {
          const link = row.url
            ? "<a href='" + escapeHtml(row.url) + "' target='_blank' rel='noopener'>" +
